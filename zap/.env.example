# ==========================================
# ZAP PLATFORM — Environment Variables
# Copy to .env and fill in your values
#
# Docker values:  REDIS_URL=redis://redis:6379
#                 EVOLUTION_API_URL=http://evolution:8080
# Local values:   REDIS_URL=redis://localhost:6379
#                 EVOLUTION_API_URL=http://localhost:8080
# ==========================================

# ---- Server ----
NODE_ENV=development
PORT=3001

# ---- Supabase ----
# Format: https://<project-ref>.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# Public anon key — safe to expose to frontend
SUPABASE_ANON_KEY=your-anon-key
# ⚠️ Service role key — never expose to frontend or client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ---- Evolution API ----
# Docker: http://evolution:8080 | Local: http://localhost:8080
EVOLUTION_API_URL=http://localhost:8080
# Must match AUTHENTICATION_API_KEY in docker-compose.yml
EVOLUTION_API_KEY=your-evolution-api-key

# ---- Redis ----
# Docker: redis://redis:6379 | Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ---- App URLs ----
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase (public — exposed to Next.js frontend) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- Short Links ----
SHORT_LINK_BASE_URL=http://localhost:3000

# ---- Integrations ----
HOTMART_WEBHOOK_SECRET=your-hotmart-hmac-secret

# ---- Email (Resend) ----
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@zap.io

# ---- AI (V1) ----
OPENAI_API_KEY=your-openai-key

# ---- Feature Flags ----
ENABLE_AI_CHAT=false
ENABLE_LEAD_SCORING=false
