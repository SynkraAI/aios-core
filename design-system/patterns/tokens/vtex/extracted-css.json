          "cssText": ".arch-section-title { font-size: 1rem; }"
        },
        {
          "selector": ".arch-bottom-feature",
          "cssText": ".arch-bottom-feature { font-size: 0.8rem; }"
        }
      ]
    },
    {
      "condition": "(max-height: 800px)",
      "ruleCount": 4,
      "rules": [
        {
          "selector": ".arch-feature-box",
          "cssText": ".arch-feature-box { font-size: 0.875rem; min-height: 2rem; }"
        },
        {
          "selector": ".arch-section-title",
          "cssText": ".arch-section-title { font-size: 0.9rem; }"
        },
        {
          "selector": ".arch-bottom-feature, .arch-addon-item span",
          "cssText": ".arch-bottom-feature, .arch-addon-item span { font-size: 0.75rem; }"
        },
        {
          "selector": ".arch-title",
          "cssText": ".arch-title { font-size: 1.5rem; }"
        }
      ]
    },
    {
      "condition": "(max-height: 700px)",
      "ruleCount": 2,
      "rules": [
        {
          "selector": ".arch-feature-box",
          "cssText": ".arch-feature-box { font-size: 0.75rem; min-height: 1.75rem; }"
        },
        {
          "selector": ".arch-section-title",
          "cssText": ".arch-section-title { font-size: 0.8rem; }"
        }
      ]
    },
    {
      "condition": "(hover: none) and (pointer: coarse)",
      "ruleCount": 1,
      "rules": [
        {
          "selector": "[data-sonner-toaster][data-lifted=\"true\"]",
          "cssText": "[data-sonner-toaster][data-lifted=\"true\"] { transform: none; }"
        }
      ]
    },
    {
      "condition": "(max-width: 600px)",
      "ruleCount": 7,
      "rules": [
        {
          "selector": "[data-sonner-toaster]",
          "cssText": "[data-sonner-toaster] { position: fixed; right: var(--mobile-offset-right); left: var(--mobile-offset-left); width: 100%; }"
        },
        {
          "selector": "[data-sonner-toaster][dir=\"rtl\"]",
          "cssText": "[data-sonner-toaster][dir=\"rtl\"] { left: calc(var(--mobile-offset-left) * -1); }"
        },
        {
          "selector": "[data-sonner-toaster] [data-sonner-toast]",
          "cssText": "[data-sonner-toaster] [data-sonner-toast] { left: 0px; right: 0px; width: calc(100% - var(--mobile-offset-left) * 2); }"
        },
        {
          "selector": "[data-sonner-toaster][data-x-position=\"left\"]",
          "cssText": "[data-sonner-toaster][data-x-position=\"left\"] { left: var(--mobile-offset-left); }"
        },
        {
          "selector": "[data-sonner-toaster][data-y-position=\"bottom\"]",
          "cssText": "[data-sonner-toaster][data-y-position=\"bottom\"] { bottom: var(--mobile-offset-bottom); }"
        },
        {
          "selector": "[data-sonner-toaster][data-y-position=\"top\"]",
          "cssText": "[data-sonner-toaster][data-y-position=\"top\"] { top: var(--mobile-offset-top); }"
        },
        {
          "selector": "[data-sonner-toaster][data-x-position=\"center\"]",
          "cssText": "[data-sonner-toaster][data-x-position=\"center\"] { left: var(--mobile-offset-left); right: var(--mobile-offset-right); transform: none; }"
        }
      ]
    },
    {
      "condition": "(prefers-reduced-motion)",
      "ruleCount": 1,
      "rules": [
        {
          "selector": ".sonner-loading-bar, [data-sonner-toast], [data-sonner-toast] > *",
          "cssText": ".sonner-loading-bar, [data-sonner-toast], [data-sonner-toast] > * { transition: none !important; animation: auto ease 0s 1 normal none running none !important; }"
        }
      ]
    }
  ],
