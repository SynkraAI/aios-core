  "mediaQueries": [
    {
      "condition": "(max-width: 1200px)",
      "ruleCount": 4,
      "rules": [
        {
          "selector": ".arch-main",
          "cssText": ".arch-main { margin: 0px 1.5rem; }"
        },
        {
